[Unit]
Description=Calendario Flask app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=1000
Group=1000
WorkingDirectory=/opt/calendario
EnvironmentFile=/opt/calendario/.env
Environment=FLASK_RUN_HOST=0.0.0.0
Environment=FLASK_RUN_PORT=5000
Environment=FLASK_DEBUG=0
ExecStart=/usr/bin/env uv run python app.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
